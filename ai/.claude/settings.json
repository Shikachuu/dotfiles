{
  "permissions": {
    "allow": [
      "mcp__ide__getDiagnostics",
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "TaskList",
      "TaskGet",
      "Task",
      "AskUserQuestion",
      "Bash(ls **)",
      "Bash(find **)",
      "Bash(pwd)",
      "Bash(echo **)",
      "Bash(cat **)",
      "Bash(head **)",
      "Bash(tail **)",
      "Bash(git status **)",
      "Bash(git log **)",
      "Bash(git diff **)",
      "Bash(git show **)",
      "Bash(git branch **)",
      "Bash(which **)",
      "Bash(whereis **)",
      "Bash(file **)",
      "Bash(stat **)",
      "Bash(wc **)",
      "Bash(tree **)"
    ],
    "deny": [
      "Bash(rm **)"
    ],
    "ask": [
      "Edit",
      "Write"
    ],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "autoUpdatesChannel": "stable"
}
